# projects.yaml — multi-project registry for agents-trello.
#
# Each entry is one project. Trello + GitHub credentials live in .env
# (shared across projects); per-project config lives here.
#
# Required fields:           id, github_repo
# Required for backend=trello: trello_board_id
# Optional:
#   - name (defaults to id)
#   - backend: trello | inmemory | sqlite (default "trello")
#   - worktree_base_dir (defaults to ~/agents/worktrees/<id>)
#   - deploy_enabled, deploy_project_name, deploy_registry

projects:
  # Real Trello-backed project — hits api.trello.com, needs creds in .env.
  - id: app
    name: Main App
    backend: trello
    trello_board_id: REPLACE_WITH_TRELLO_BOARD_ID_1
    github_repo: my-org/main-app
    worktree_base_dir: ~/agents/worktrees/app
    deploy_enabled: false

  # Persistent local mock — no Trello account needed. State lives in the
  # shared SQLite DB (mock_* tables). Survives restarts.
  - id: sandbox
    name: Sandbox
    backend: sqlite
    github_repo: my-org/sandbox-app
    worktree_base_dir: ~/agents/worktrees/sandbox

  # Throw-away in-memory mock — wiped on restart. Good for ad-hoc demos.
  - id: ephemeral
    name: Ephemeral
    backend: inmemory
    github_repo: my-org/ephemeral
    worktree_base_dir: ~/agents/worktrees/ephemeral
