# Trello
TRELLO_API_KEY=your_trello_api_key
TRELLO_API_TOKEN=your_trello_api_token
TRELLO_BOARD_ID=your_board_id
TRELLO_WEBHOOK_SECRET=your_webhook_callback_url_base  # used for HMAC verification

# GitHub
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret
GITHUB_REPO=owner/repo  # e.g. acme/my-project

# Anthropic (for the Claude Code agent)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Agent
AGENT_MAX_CONCURRENT=4          # max concurrent claude subprocess runs
AGENT_TIMEOUT_SECONDS=1800      # 30 min default per agent run
WORKTREE_BASE_DIR=~/agents/worktrees

# Server
WEBHOOK_BASE_URL=https://your-tunnel.ngrok.io  # public URL for Trello/GitHub callbacks
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_PATH=./data/agents_trello.db

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json  # json or console
